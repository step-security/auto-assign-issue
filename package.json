{
    "name": "auto-assign-issue",
    "version": "4.0.0",
    "private": true,
    "description": "GitHub action that auto-assigns issues to users",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "lint": "eslint src/**",
        "prettier": "prettier --write \"**/*.{html,js,json,md,yaml,yml}\"",
        "prettier:verify": "prettier --check \"**/*.{html,js,json,md,yaml,yml}\"",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
        "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
        "prepare": "husky || true",
        "precommit": "lint-staged",
        "build": "ncc build ./src/index.js -m -o dist",
        "all": "npm run prettier && npm run lint && npm run test && npm run build"
    },
    "lint-staged": {
        "*.{html,js,json,md,yaml,yml}": [
            "prettier --write \"**/*.{html,js,json,md,yaml,yml}\""
        ],
        "./src/**/*.js": [
            "eslint",
            "cross-env NODE_OPTIONS=--experimental-vm-modules jest --bail --findRelatedTests --passWithNoTests"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/step-security/auto-assign-issue.git"
    },
    "keywords": [
        "github",
        "action",
        "issue",
        "assign"
    ],
    "author": "step-security",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/step-security/auto-assign-issue/issues"
    },
    "homepage": "https://github.com/step-security/auto-assign-issue#readme",
    "dependencies": {
        "@actions/core": "^1.11.1",
        "@actions/github": "^6.0.1",
        "axios": "^1.9.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vercel/ncc": "^0.38.3",
        "cross-env": "^10.1.0",
        "eslint": "^10.4.1",
        "eslint-plugin-jest": "^29.15.2",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.3"
    },
    "engines": {
        "node": ">=24"
    },
    "volta": {
        "node": "24.15.0"
    }
}
